# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/helpdesk?schema=public"

BETTER_AUTH_SECRET="replace-with-32-plus-char-random-string"
BETTER_AUTH_URL="http://localhost:5150"

CLIENT_ORIGIN="http://localhost:5173"

SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="replace-with-secure-password"

# Webhook secret — required
# Sent by callers in the x-webhook-secret header; requests without it are rejected with 401
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET="replace-with-random-secret"

# SendGrid Inbound Parse
# Optional: set to enable ECDSA signature verification on inbound webhook payloads
# Obtain from: SendGrid Dashboard → Settings → Mail Settings → Signed Event Webhooks
SENDGRID_WEBHOOK_PUBLIC_KEY=""

# OpenAI API key — required for the AI reply polish feature
OPENAI_API_KEY=""

# Sentry (error monitoring — leave blank to disable)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production